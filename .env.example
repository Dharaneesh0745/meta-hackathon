# ──────────────────────────────────────────
# Jira-to-PR OpenEnv — Required Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# For HF Spaces deployment, add these as Secrets in Settings → Variables and secrets.
# The hackathon evaluator injects their own values at runtime.

# Hugging Face API Token (required for inference)
HF_TOKEN=your_hf_token_here

# LLM Model to use for the agent
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# API endpoint for the LLM
API_BASE_URL=https://router.huggingface.co/v1
